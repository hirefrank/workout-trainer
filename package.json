{
  "name": "workout-trainer",
  "version": "1.0.0",
  "description": "16-week progressive kettlebell training program tracker",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs && wrangler dev",
    "dev:local": "node build.mjs && wrangler dev --config wrangler.local.jsonc",
    "typecheck": "tsc --noEmit",
    "deploy": "node build.mjs && wrangler deploy",
    "deploy:local": "node build.mjs && wrangler deploy --config wrangler.local.jsonc",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20251113.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.5.4",
    "js-yaml": "^4.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.40.2",
    "yaml": "^2.8.2"
  },
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316"
}
